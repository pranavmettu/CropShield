# ── Data files (never commit raw data) ───────────────────────────────────────
data/raw/
data/interim/
data/processed/
data/external/
*.csv
*.parquet
*.feather
*.pkl
*.h5
*.hdf5
*.nc
*.tif
*.tiff
*.geojson
*.shp
*.shx
*.dbf
*.prj

# Keep directory structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ── Model artifacts ──────────────────────────────────────────────────────────
# Trained-model artifact dirs at repo root or under data/ (NOT the source
# package src/cropshield/models/, which must stay tracked).
/models/
data/models/
*.joblib
*.model
*.bin
*.pkl

# ── Reports / figures (generated outputs) ────────────────────────────────────
reports/figures/
!reports/figures/.gitkeep

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

