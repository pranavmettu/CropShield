# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real keys.

# USDA NASS Quick Stats API key
# Register at: https://quickstats.nass.usda.gov/api
NASS_API_KEY=your_nass_api_key_here

# NASA POWER does not require an API key (as of 2024)
# No key needed for the MVP weather fetcher

# Optional: future integrations
# NOAA_CDO_TOKEN=your_noaa_token_here
